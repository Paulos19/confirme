      "name": "Evo - Notificar Assistente"
    },
    {
      "parameters": {
        "jsCode": "// O n8n expõe todos os itens recebidos no array $input.all()\n// Vamos mapear (iterar) sobre todos eles e devolver o array modificado\nreturn $input.all().map(item => {\n  const data = item.json;\n  \n  // 1. Tratamento do Telefone (adiciona 55 do Brasil se não tiver)\n  let fone = data.patientMobile.replace(/\\D/g, '');\n  if (!fone.startsWith('55')) {\n    fone = '55' + fone;\n  }\n\n  // 2. Retornamos o objeto com o telefone formatado\n  // O \"data.customMessage\" já vem pronto do Next.js, então o n8n repassa automaticamente com o \"...data\"\n  return {\n    json: {\n      ...data,\n      patientMobileEvo: fone\n    }\n  };\n});"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        192,
        0
      ],
      "id": "2935efc4-bbad-4a5a-aee0-faaeb42b568d",
      "name": "Formatar Dados"
    },
    {
      "parameters": {
        "promptType": "define",
        "text": "={{ $json.text }}",
        "options": {
          "systemMessage": "Você é um classificador semântico para uma clínica médica. Sua única função é ler a mensagem do paciente e classificar sua intenção.\nRetorne ESTritamente e APENAS uma das três palavras abaixo, sem pontuação ou explicações:\nCONFIRMADO (se ele der certeza que vai)\nCANCELADO (se ele desmarcar ou disser que não pode ir)\nOUTROS (se for uma dúvida, se ele pedir para reagendar sem dar certeza, ou se a mensagem for ininteligível)."
        }
      },
      "type": "@n8n/n8n-nodes-langchain.agent",
      "typeVersion": 3.1,
      "position": [
        192,
        432
      ],
      "id": "d94afe8f-8303-4451-9ab0-65f2f05a37bd",
      "name": "IA - Entender Resposta"
    },
    {
      "parameters": {
        "jsCode": "// Procura a resposta da IA nos vários formatos possíveis (incluindo o 'output' do Langchain/Gemini)\nlet intent = $json.output || $json.message?.content || $json.text || \"OUTROS\";\n\nreturn {\n  ...$json, \n  intentClassified: String(intent).trim().toUpperCase() \n};"
      },
