    {
      "parameters": {
        "jsCode": "// O payload da Evo geralmente vem dentro de body.data\nconst payload = $json.body?.data || $json.data || $json.body;\n\n// 1. Barreira de Segurança: Ignorar eventos irrelevantes\nif (!payload || !payload.key) return []; // Não é uma mensagem\nif (payload.key.fromMe) return []; // É uma mensagem enviada por nós mesmos\nif (payload.key.remoteJid.includes('@g.us')) return []; // É de um grupo\n\n// 2. Extração segura do texto (Evo manda em lugares diferentes dependendo se tem link ou não)\nlet text = \"\";\nif (payload.message?.conversation) {\n  text = payload.message.conversation;\n} else if (payload.message?.extendedTextMessage?.text) {\n  text = payload.message.extendedTextMessage.text;\n}\n\n// 3. Pega só os números do telefone (ex: 554199999999)\nconst phone = payload.key.remoteJid.split('@')[0];\n\nreturn {\n  remoteJid: payload.key.remoteJid,\n  phone: phone,\n  text: text.trim().toLowerCase(),\n  patientName: payload.pushName || \"Paciente\"\n};"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -16,
        432
      ],
      "id": "70b428bd-85b3-40e4-9fe3-9052e48f1caa",
